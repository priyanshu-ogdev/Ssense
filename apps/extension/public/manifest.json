{
  "manifest_version": 3,
  "name": "Ssense - DPDP Compliance Shield",
  "version": "0.1.0",
  "description": "Real-time enforcement of India's Digital Personal Data Protection Act",
  "permissions": [
    "sidePanel",
    "storage",
    "nativeMessaging",
    "scripting",
    "tabs"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/api-spoof.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content/extractor.js", "content/dark-pattern-blocker.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Ssense DPDP Shield"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}